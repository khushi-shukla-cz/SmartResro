<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main Material 3 theme for the whole app -->
    <style name="Theme.SmartRestro" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary colours -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Accent / secondary -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Surface / background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Status bar colour -->
        <item name="android:statusBarColor">@color/primary_dark</item>

        <!-- Material 3 error colour -->
        <item name="colorError">@color/error</item>
    </style>

    <!-- Splash screen theme: fullscreen with gradient background, no action bar -->
    <style name="Theme.SmartRestro.Splash" parent="Theme.SmartRestro">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/splash_start</item>
    </style>

</resources>
