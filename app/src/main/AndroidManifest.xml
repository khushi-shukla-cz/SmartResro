<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartRestro">

        <!-- Splash Screen -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SmartRestro.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Home Screen -->
        <activity
            android:name=".activities.HomeActivity"
            android:exported="false" />

        <!-- Menu Screen -->
        <activity
            android:name=".activities.MenuActivity"
            android:exported="false" />

        <!-- Order Screen -->
        <activity
            android:name=".activities.OrderActivity"
            android:exported="false" />

        <!-- My Orders / Cart Screen -->
        <activity
            android:name=".activities.MyOrdersActivity"
            android:exported="false" />

        <!-- About Us Screen -->
        <activity
            android:name=".activities.AboutActivity"
            android:exported="false" />

        <!-- Network Receiver: Monitors internet connectivity -->
        <receiver
            android:name=".receivers.NetworkReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <!-- Battery Receiver: Monitors battery status -->
        <receiver
            android:name=".receivers.BatteryReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BATTERY_LOW" />
                <action android:name="android.intent.action.BATTERY_OKAY" />
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
