<?xml version="1.0" encoding="utf-8"?>
<!-- Individual order item card used in the My Orders RecyclerView -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Food thumbnail image -->
        <ImageView
            android:id="@+id/ivOrderImage"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_food_placeholder"
            android:scaleType="centerCrop"
            android:contentDescription="Food image"
            android:background="@drawable/bg_image_rounded" />

        <!-- Order details column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Food name -->
            <TextView
                android:id="@+id/tvOrderFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Food Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Size label -->
            <TextView
                android:id="@+id/tvOrderSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Size: Medium"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <!-- Quantity label -->
            <TextView
                android:id="@+id/tvOrderQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Qty: 1"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <!-- Add-ons label -->
            <TextView
                android:id="@+id/tvOrderAddOns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add-ons: None"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <!-- Item total price -->
            <TextView
                android:id="@+id/tvOrderTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹299.00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- Remove button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemove"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textSize="14sp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:layout_marginStart="8dp"
            app:backgroundTint="@color/error_light"
            android:textColor="@color/error"
            app:cornerRadius="8dp"
            style="@style/Widget.Material3.Button.TonalButton" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
